# ─── Copia este archivo a .env y ajusta los valores ──────────────────────────
# cp .env.example .env

# Base de datos
DB_USERNAME=postgres
DB_PASSWORD=cambia_esto_en_produccion

# Redis (dejar vacío deshabilita la contraseña)
REDIS_PASSWORD=

# JWT — mínimo 32 caracteres, usa un valor aleatorio en producción
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio_32chars
JWT_EXPIRATION_MS=86400000

# CORS — debe coincidir con la URL donde se sirve el frontend
CORS_ALLOWED_ORIGINS=http://localhost

# Email (stub = solo loguea, resend = envía emails reales)
EMAIL_PROVIDER=stub
RESEND_API_KEY=

# Puerto expuesto del frontend (default: 80)
FRONTEND_PORT=80
